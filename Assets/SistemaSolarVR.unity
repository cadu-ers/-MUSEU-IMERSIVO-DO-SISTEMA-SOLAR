  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PlanetaInfo
  nomePlaneta: "J\xFApiter"
  descricaoPlaneta: "O maior planeta do Sistema Solar. \xC9 um gigante gasoso com
    uma Grande Mancha Vermelha (uma tempestade que dura h\xE1 s\xE9culos). Possui
    um forte campo magn\xE9tico e muitos sat\xE9lites."
  curiosidades:
  - Tem pelo menos 95 luas conhecidas
  - "Sua Grande Mancha Vermelha \xE9 uma tempestade com 300 anos"
  - "\xC9 t\xE3o grande que poderia conter 1.300 Terras em seu interior"
  narracao: {fileID: 8300000, guid: 809c5f4fb7a77a242bcd4e90fc5f5482, type: 3}
