  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PlanetaInfo
  nomePlaneta: "Merc\xFArio"
  descricaoPlaneta: "O planeta mais pr\xF3ximo do Sol. \xC9 pequeno e rochoso, com
    uma superf\xEDcie coberta de crateras. Tem uma temperatura extrema, variando
    de -180\xB0C \xE0 noite para 430\xB0C durante o dia."
  curiosidades:
  - "\xC9 o menor planeta do Sistema Solar"
  - Tem um dia mais longo que seu ano orbital
  - "Sua \xF3rbita \xE9 a mais pr\xF3xima do Sol de todas"
  narracao: {fileID: 8300000, guid: 35437feaf15cc8b4f849b3bdfa7fe0e8, type: 3}
