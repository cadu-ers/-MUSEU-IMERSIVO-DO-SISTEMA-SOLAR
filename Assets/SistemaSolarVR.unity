  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PlanetaInfo
  nomePlaneta: "Plut\xE3o"
  descricaoPlaneta: "Um planeta an\xE3o localizado al\xE9m de Netuno. \xC9 pequeno
    e gelado, coberto por uma mistura de gelo de nitrog\xEAnio, metano e mon\xF3xido
    de carbono. Possui uma lua grande chamada Caronte, que \xE9 quase do mesmo tamanho."
  curiosidades:
  - "Foi reclassificado de planeta para planeta an\xE3o em 2006"
  - "Sua lua Caronte \xE9 proporcionalmente t\xE3o grande que orbitam um ao outro"
  - "Leva 248 anos para completar uma \xF3rbita ao redor do Sol"
  narracao: {fileID: 0}
